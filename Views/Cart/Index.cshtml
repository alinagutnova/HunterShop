@model Cart
@{
    ViewData["Title"] = "Корзина";
}

<div class="text-left">
    <h1 class="display-4">Корзина</h1>
    @if (Model == null)
    {
        <h3>У вас пока нет покупок</h3>
    }
    else
    {
        <div class="row">
            <div class="col">
                <table class="table">
                    <thead>
                        <trow>
                            <th>Название</th>
                            <th>Цена</th>
                            <th>Количество</th>
                            <th>Стоимость</th>
                        </trow>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Items)
                        {
                            <tr>
                                <td>@item.Product.Name</td>
                                <td>@item.Product.Cost</td>
                                <td>@item.Amount</td>
                                <td>@item.Cost</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>
